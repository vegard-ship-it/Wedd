generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// Auth (NextAuth.js)
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Users & Wedding
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  weddings WeddingMember[]
  chatMessages ChatMessage[]
}

model Wedding {
  id          String    @id @default(cuid())
  name        String    // f.eks. "Ola & Kari sitt bryllup"
  date        DateTime?
  venue       String?
  description String?   @db.Text
  currency    String    @default("NOK")
  timezone    String    @default("Europe/Oslo")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members          WeddingMember[]
  guests           Guest[]
  guestGroups      GuestGroup[]
  budgetCategories BudgetCategory[]
  budgetItems      BudgetItem[]
  vendors          Vendor[]
  timelineEvents   TimelineEvent[]
  invitations      Invitation[]
  albums           Album[]
  photos           Photo[]
  emails           Email[]
  emailTemplates   EmailTemplate[]
  chatMessages     ChatMessage[]
  notifications    Notification[]
}

model WeddingMember {
  id        String          @id @default(cuid())
  role      WeddingRole     @default(ORGANIZER)
  userId    String
  weddingId String
  createdAt DateTime        @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@unique([userId, weddingId])
}

enum WeddingRole {
  ORGANIZER
  PARTNER
  PLANNER
  VIEWER
}

// ============================================
// Guests
// ============================================

model Guest {
  id              String      @id @default(cuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  rsvpStatus      RsvpStatus  @default(PENDING)
  rsvpDate        DateTime?
  plusOne          Boolean     @default(false)
  plusOneName      String?
  dietaryNeeds    String?
  allergies       String?
  tableNumber     Int?
  notes           String?     @db.Text
  accessToken     String?     @unique @default(cuid()) // For gjesteportal-tilgang
  weddingId       String
  groupId         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  wedding     Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  group       GuestGroup?  @relation(fields: [groupId], references: [id])
  invitations Invitation[]
  photos      Photo[]      @relation("GuestPhotos")
}

model GuestGroup {
  id        String   @id @default(cuid())
  name      String   // f.eks. "Familie brud", "Venner brudgom"
  color     String?  // For visuell gruppering
  weddingId String
  createdAt DateTime @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guests  Guest[]
}

enum RsvpStatus {
  PENDING
  ACCEPTED
  DECLINED
  MAYBE
}

// ============================================
// Budget
// ============================================

model BudgetCategory {
  id            String   @id @default(cuid())
  name          String   // f.eks. "Venue", "Catering", "Fotograf"
  budgetAmount  Float    @default(0)
  icon          String?
  color         String?
  sortOrder     Int      @default(0)
  weddingId     String
  createdAt     DateTime @default(now())

  wedding Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  items   BudgetItem[]
}

model BudgetItem {
  id          String         @id @default(cuid())
  name        String
  amount      Float
  type        BudgetItemType @default(EXPENSE)
  isPaid      Boolean        @default(false)
  paidDate    DateTime?
  dueDate     DateTime?
  notes       String?        @db.Text
  vendorId    String?
  categoryId  String
  weddingId   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  category BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  wedding  Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  vendor   Vendor?        @relation(fields: [vendorId], references: [id])
}

enum BudgetItemType {
  EXPENSE
  SAVING
  INCOME
}

// ============================================
// Vendors (Leverandører)
// ============================================

model Vendor {
  id           String        @id @default(cuid())
  name         String
  category     VendorCategory
  contactName  String?
  email        String?
  phone        String?
  website      String?
  address      String?
  price        Float?
  status       VendorStatus  @default(CONSIDERING)
  contractUrl  String?
  notes        String?       @db.Text
  rating       Int?          // 1-5
  weddingId    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  wedding     Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  budgetItems BudgetItem[]
}

enum VendorCategory {
  VENUE
  CATERING
  PHOTOGRAPHER
  VIDEOGRAPHER
  FLORIST
  MUSIC_DJ
  MUSIC_BAND
  CAKE
  DRESS
  SUIT
  HAIR_MAKEUP
  TRANSPORT
  DECORATION
  STATIONERY
  RINGS
  OFFICIANT
  OTHER
}

enum VendorStatus {
  CONSIDERING
  CONTACTED
  MEETING_SCHEDULED
  QUOTE_RECEIVED
  BOOKED
  DEPOSIT_PAID
  PAID_IN_FULL
  CANCELLED
}

// ============================================
// Timeline & Deadlines
// ============================================

model TimelineEvent {
  id          String            @id @default(cuid())
  title       String
  description String?           @db.Text
  date        DateTime
  type        TimelineEventType @default(MILESTONE)
  isCompleted Boolean           @default(false)
  reminder    Boolean           @default(true)
  reminderDays Int?             @default(7) // Dager før for påminnelse
  weddingId   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

enum TimelineEventType {
  MILESTONE
  DEADLINE
  REMINDER
  APPOINTMENT
  PAYMENT_DUE
  TASK
}

// ============================================
// Invitations
// ============================================

model Invitation {
  id          String           @id @default(cuid())
  templateId  String?
  guestId     String
  sentAt      DateTime?
  openedAt    DateTime?
  respondedAt DateTime?
  method      InvitationMethod @default(EMAIL)
  status      InvitationStatus @default(DRAFT)
  weddingId   String
  createdAt   DateTime         @default(now())

  guest   Guest   @relation(fields: [guestId], references: [id], onDelete: Cascade)
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

enum InvitationMethod {
  EMAIL
  SMS
  PHYSICAL
}

enum InvitationStatus {
  DRAFT
  SENT
  DELIVERED
  OPENED
  RESPONDED
  FAILED
}

// ============================================
// Photos & Albums
// ============================================

model Album {
  id          String   @id @default(cuid())
  name        String
  description String?
  coverUrl    String?
  isPublic    Boolean  @default(false) // Synlig for gjester
  weddingId   String
  createdAt   DateTime @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  photos  Photo[]
}

model Photo {
  id           String   @id @default(cuid())
  url          String
  thumbnailUrl String?
  caption      String?
  uploadedBy   String?  // Navn eller bruker-ID
  albumId      String?
  weddingId    String
  createdAt    DateTime @default(now())

  album   Album?  @relation(fields: [albumId], references: [id])
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  taggedGuests Guest[] @relation("GuestPhotos")
}

// ============================================
// Email
// ============================================

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String   @db.Text
  type      String   // f.eks. "save-the-date", "invitation", "reminder", "thank-you"
  weddingId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Email {
  id          String      @id @default(cuid())
  to          String
  subject     String
  body        String      @db.Text
  status      EmailStatus @default(DRAFT)
  sentAt      DateTime?
  direction   EmailDirection @default(OUTGOING)
  weddingId   String
  createdAt   DateTime    @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

enum EmailStatus {
  DRAFT
  QUEUED
  SENT
  DELIVERED
  FAILED
}

enum EmailDirection {
  INCOMING
  OUTGOING
}

// ============================================
// AI Chat
// ============================================

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // "user" | "assistant"
  content   String   @db.Text
  userId    String
  weddingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

// ============================================
// Notifications
// ============================================

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  link      String?
  weddingId String
  createdAt DateTime         @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  RSVP_RECEIVED
  DEADLINE_APPROACHING
  PAYMENT_DUE
  VENDOR_UPDATE
  PHOTO_UPLOADED
  EMAIL_RECEIVED
  GENERAL
}
