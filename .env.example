# ===========================================
# Wedding Planner — Miljøvariabler
# ===========================================
# Kopier denne filen til .env.local og fyll inn verdiene
# ALDRI commit .env.local til git!

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/wedding_planner?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/wedding_planner?schema=public"

# -------------------------------------------
# NextAuth.js
# -------------------------------------------
# Generer med: openssl rand -base64 32
NEXTAUTH_SECRET="din-hemmelige-nøkkel-her"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (valgfritt)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -------------------------------------------
# Anthropic (Claude AI Chat)
# -------------------------------------------
ANTHROPIC_API_KEY=""

# -------------------------------------------
# Resend (E-post)
# -------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="bryllup@dittdomene.no"

# -------------------------------------------
# Uploadthing (Bildeopplasting)
# -------------------------------------------
UPLOADTHING_TOKEN=""

# -------------------------------------------
# App-konfigurasjon
# -------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Bryllupsplanleggeren"

# -------------------------------------------
# Cron / Scheduled Jobs (påminnelser, frister)
# -------------------------------------------
CRON_SECRET="hemmelig-cron-nøkkel"

# -------------------------------------------
# Valgfritt: Analytics
# -------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST=""

# -------------------------------------------
# Valgfritt: Sentry (feilovervåking)
# -------------------------------------------
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""
